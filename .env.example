# ── Server ────────────────────────────────────────────────────────────────
PORT=3030
# Team access tokens: name:token pairs, comma-separated. Generate with:
#   openssl rand -hex 24
AUTH_TOKENS=viral:CHANGE_ME,teammate1:CHANGE_ME
# Token for POST /admin/sync (one-click upstream pull)
ADMIN_TOKEN=CHANGE_ME
# Engine subprocess timeout (ms)
ENGINE_TIMEOUT_MS=600000
# PYTHON_BIN=python3

# ── Headless reasoning (engine planner + reranker) — ONE of these ─────────
# Priority: Gemini > OpenAI > xAI > OpenRouter. Gemini Flash is the cheapest.
GOOGLE_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=        # also unlocks --deep-research (Perplexity Sonar)

# ── Web search backend (unlocks --auto-resolve entity resolution) ─────────
# ONE of: BRAVE_API_KEY / EXA_API_KEY / SERPER_API_KEY / PARALLEL_API_KEY
BRAVE_API_KEY=

# ── X / Twitter (pick one) ─────────────────────────────────────────────────
# xAI is the cleanest server-side option; browser-cookie auth does NOT work headless.
XAI_API_KEY=

# ── TikTok / Instagram / Threads / Pinterest + Reddit fallback ────────────
SCRAPECREATORS_API_KEY=
INCLUDE_SOURCES=tiktok,instagram

# ── Optional sources ───────────────────────────────────────────────────────
# BSKY_HANDLE=you.bsky.social
# BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# APIFY_API_TOKEN=
# GH_TOKEN=                  # lets the gh CLI authenticate for GitHub source
