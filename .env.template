# ════════════════════════════════════════════════════════════════════════
# viral-mcp .env template — copy to .env and fill in.
# Tiers: [CORE] server won't be useful without it · [HIGH] strongly
# recommended for people/company/market/finance/crypto research ·
# [OPT] nice to have. Free sources (Reddit, HN, Polymarket) need no keys.
# ════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────
PORT=3030

# [CORE] Team access tokens, name:token pairs (generate: openssl rand -hex 24)
AUTH_TOKENS=viral:CHANGE_ME,teammate1:CHANGE_ME

# [CORE] Token for POST /admin/sync (one-click upstream pull)
ADMIN_TOKEN=CHANGE_ME

# Engine subprocess timeout in ms (deep runs can take ~5 min)
ENGINE_TIMEOUT_MS=600000
# PYTHON_BIN=python3

# ── Reasoning provider — engine's headless planner + reranker ─────────────
# [CORE] ONE of these. Priority: Gemini > OpenAI > xAI > OpenRouter.
# Gemini Flash is the cheapest and first in line.
GOOGLE_API_KEY=
# OPENAI_API_KEY=
# Pin a provider explicitly (gemini|openai|xai|openrouter):
# LAST30DAYS_REASONING_PROVIDER=gemini
# Override the models it uses:
# LAST30DAYS_PLANNER_MODEL=
# LAST30DAYS_RERANK_MODEL=

# ── Web search backend — unlocks --auto-resolve entity resolution ─────────
# [CORE] ONE of these. Priority: Brave > Exa > Serper > Parallel.
# NOTE: with multiple set, Brave wins — set only the one you want used.
BRAVE_API_KEY=
# EXA_API_KEY=               # semantic search, good for niche entities
# SERPER_API_KEY=            # Google SERP results
# PARALLEL_API_KEY=          # parallel.ai

# ── X / Twitter ────────────────────────────────────────────────────────────
# [HIGH] Where finance/crypto sentiment and people-research live.
# xAI is the cleanest server-side option (browser-cookie auth needs a desktop).
XAI_API_KEY=
# Alternative paid backend (xquik.com), or pin which backend wins:
# XQUIK_API_KEY=
# LAST30DAYS_X_BACKEND=xai

# ── ScrapeCreators — TikTok / Instagram / Threads / Pinterest ─────────────
# [HIGH] Also a Reddit fallback when public endpoints rate-limit.
# 10K free calls: scrapecreators.com
SCRAPECREATORS_API_KEY=
INCLUDE_SOURCES=tiktok,instagram
# Add threads,pinterest to the list above if you want them.
# EXCLUDE_SOURCES=

# ── GitHub ────────────────────────────────────────────────────────────────
# [HIGH] Free. Powers person-mode (what is someone shipping?) and repo intel.
# Fine-grained PAT with public-repo read access is enough.
GH_TOKEN=

# ── YouTube on a datacenter IP (Hetzner/AWS/DO) ───────────────────────────
# [HIGH if YouTube matters] YouTube bot-walls datacenter IPs (search returns
# 0 results). The engine can route yt-dlp over SSH through any residential
# machine (e.g. your Mac or home server) that has yt-dlp installed:
# LAST30DAYS_YOUTUBE_SSH_HOST=my-home-mac    # an alias from ~/.ssh/config
# LAST30DAYS_TRANSCRIPT_TIMEOUT=60

# ── Perplexity deep research ──────────────────────────────────────────────
# [OPT] Unlocks --deep-research via OpenRouter (Sonar Pro, ~$0.90/query).
# Worth it for high-stakes finance/company deep dives.
# OPENROUTER_API_KEY=

# ── Bluesky ───────────────────────────────────────────────────────────────
# [OPT] Free. Growing tech/crypto community. App password: bsky.app/settings
# BSKY_HANDLE=you.bsky.social
# BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# BSKY_SEARCH_HOST=api.bsky.app

# ── Fallbacks & extras ────────────────────────────────────────────────────
# [OPT] Apify: backup scraper for Reddit/TikTok/Instagram when
# ScrapeCreators credits run out. Free tier available.
# APIFY_API_TOKEN=
# [OPT] Truth Social: free token; market-moving political posts.
# TRUTHSOCIAL_TOKEN=

# ── Debug ─────────────────────────────────────────────────────────────────
# LAST30DAYS_DEBUG=1
